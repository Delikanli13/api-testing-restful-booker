    {
      "name": "Get a single booking",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.expect(pm.response.code).to.equal(200);",
              "});",
              "",
              "pm.test(\"Response has required fields\", function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body).to.have.property(\"firstname\");",
              "    pm.expect(body).to.have.property(\"lastname\");",
              "    pm.expect(body).to.have.property(\"totalprice\");",
              "    pm.expect(body).to.have.property(\"depositpaid\");",
              "    pm.expect(body).to.have.property(\"bookingdates\");",
              "});",
              "",
              "pm.test(\"totalprice is a number\", function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body.totalprice).to.be.a(\"number\");",
              "});",
              "",
              "pm.test(\"depositpaid is a boolean\", function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body.depositpaid).to.be.a(\"boolean\");",
              "});",
              "",
              "",
              "// Schema validation",
              "const schema = {",
              "    type: \"object\",",
              "    required: [\"firstname\", \"lastname\", \"totalprice\", \"depositpaid\", \"bookingdates\"],",
              "    properties: {",
              "        firstname:   { type: \"string\" },",
              "        lastname:    { type: \"string\" },",
              "        //totalprice:  { type: \"number\" },",
              "        totalprice:  { type: \"string\"},",
              "        depositpaid: { type: \"boolean\" },",
              "        bookingdates: {",
              "            type: \"object\",",
              "            required: [\"checkin\", \"checkout\"],",
              "            properties: {",
              "                checkin:  { type: \"string\" },",
              "                checkout: { type: \"string\" }",
              "            }",
              "        },",
              "        additionalneeds: { type: \"string\" }",
              "    },",
              "    additionalProperties: false",
              "};",
              "",
              "pm.test(\"Response matches booking schema\", function () {",
              "    const body = pm.response.json();",
              "    const result = tv4.validate(body, schema);",
              "    pm.expect(result).to.be.true;",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
