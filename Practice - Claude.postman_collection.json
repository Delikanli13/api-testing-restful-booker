    {
      "name": "Create a booking",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.expect(pm.response.code).to.equal(200);",
              "});",
              "",
              "pm.test(\"Response has bookingid\", function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body).to.have.property(\"bookingid\");",
              "});",
              "",
              "pm.test(\"bookingid is a number\", function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body.bookingid).to.be.a(\"number\");",
              "});",
              "",
              "// THIS is the chaining part — save the ID for the next request",
              "const body = pm.response.json();",
              "pm.collectionVariables.set(\"bookingId\", body.bookingid);",
              "console.log(\"Saved bookingId:\", body.bookingid);",
              "",
              "pm.test(\"Firstname matches data file\", function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body.booking.firstname).to.equal(pm.iterationData.get(\"firstname\"));",
              "});",
              "",
              "pm.test(\"Lastname matches data file\", function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body.booking.lastname).to.equal(pm.iterationData.get(\"lastname\"));",
              "});",
              "",
              "pm.test(\"Totalprice matches data file\", function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body.booking.totalprice).to.equal(Number(pm.iterationData.get(\"totalprice\")));",
              "});",
              "",
              "const createSchema = {",
              "    type: \"object\",",
              "    required: [\"bookingid\", \"booking\"],",
              "    properties: {",
              "        bookingid: { type: \"number\" },",
              "        booking: {",
              "            type: \"object\",",
              "            required: [\"firstname\", \"lastname\", \"totalprice\", \"depositpaid\", \"bookingdates\"],",
              "            properties: {",
              "                firstname:   { type: \"string\" },",
              "                lastname:    { type: \"string\" },",
              "                totalprice:  { type: \"number\" },",
              "                depositpaid: { type: \"boolean\" },",
              "                bookingdates: {",
              "                    type: \"object\",",
              "                    required: [\"checkin\", \"checkout\"],",
              "                    properties: {",
              "                        checkin:  { type: \"string\" },",
              "                        checkout: { type: \"string\" }",
              "                    }",
              "                }",
              "            }",
              "        }",
              "    }",
              "};",
              "",
              "pm.test(\"Create response matches schema\", function () {",
              "    const body = pm.response.json();",
              "    const result = tv4.validate(body, schema);",
              "    pm.expect(result).to.be.true;",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
