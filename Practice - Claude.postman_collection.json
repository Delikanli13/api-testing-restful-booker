              "}); ",
              "",
              "pm.test(\"Lastname was updated to Smith\", function () {",
              "    pm.expect(body.lastname).to.equal(\"Smith\");",
              "});",
              "",
              "pm.test(\"Total price was updated to 200\", function () {",
              "    pm.expect(body.totalprice).to.equal(200);",
